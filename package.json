{
  "name": "invoice-extractor",
  "version": "1.0.0",
  "description": "Invoice data extraction and validation using AI via OpenRouter API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
